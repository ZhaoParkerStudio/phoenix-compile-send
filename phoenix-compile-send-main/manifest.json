{
  "manifest_version": 3,
  "name": "鳳凰編譯·快信",
  "version": "2.0",
  "description": "鳳凰編譯·快信｜北京編譯中心一鍵發信工具。支援AI生成郵件，快速傳送圖片及影片任務給GFX/NGB同事。",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.emailjs.com/*",
    "https://api.deepseek.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "鳳凰編譯·快信"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}